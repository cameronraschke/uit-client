	PCNTOFSECTOR='20'
	WMODE='random'
	writeDisk_Shred
	
	printf '\n'
	printf '%s\n' "Step [2/3]:"
	secErase_Shred
	secUnlock_Shred
	
	printf '\n'
	printf '%s\n' "Step [3/3]:"
	printf "%s \n" "Skipped (verify)"
	# PCNTOFSECTOR='10'
	# CHAR='0'
	# vrfyDisk_Shred
}



