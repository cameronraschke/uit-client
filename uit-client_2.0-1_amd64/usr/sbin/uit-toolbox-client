	printf '\n'
	tput bold
	tput setaf 1
	printf '%s\n' "| |    | |  | |     | |"
	printf '%s\n' "| |    | |  | |_____| |"
	printf '%s\n' "| |    | |  | |_____| |"
	printf '%s\n' "| |____| |  | |     | |"
	printf '%s\n' "\________/  | |     | |"
	tput sgr0
	printf '\n'
	printf '%s\n' "------------------------------"
}

