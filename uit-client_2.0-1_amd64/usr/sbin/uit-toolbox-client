	footer
	printf '%s\n' "${BOLD}UIT-Toolbox Client running in ${BLUE}${RMODE}${RESET}${BOLD}. Erasing disk ${BLUE}${CLIENTDISK}${RESET}${BOLD}.${RESET}"
	
	printf '\n'
	printf '\n'
	secUnlock_Shred
}



function clientselect_Clone {
	footer
	printf '%s\n' "${BOLD}Please select a ${BOLD}${BLUE}clone mode${RESET}${BOLD}: "
	printf '   %s\n' "${BOLD}${GREEN}[1]${RESET} ${BOLD}Restore${RESET} ${DIM}(server -> client)${RESET}"
	printf '   %s\n' "${BOLD}${GREEN}[2]${RESET} ${BOLD}Save${RESET} ${DIM}(client -> server)${RESET}"
	read -n1 -p "${BOLD}Enter [1-2]:${RESET} " cloneMode
	printf '\n'
	printf '\n'
	case $cloneMode in
		1)
			cloneMode="restoredisk"
		;;
		2)
			cloneMode="savedisk"
		;;
		*)
			printf '%s\n' "${BOLD}${RED}Error - Invalid input${RESET}"
		;;
	esac

	printf '%s\n' "${BOLD}Select which ${BOLD}${BLUE}image${RESET} you are cloning:${RESET} "
	printf '   %s\n' "${BOLD}${GREEN}[1]${RESET} ${BOLD}Tech Commons HP laptops${RESET}"
	printf '   %s\n' "${BOLD}${GREEN}[2]${RESET} ${BOLD}Tech Commons Dell laptops${RESET}"
	printf '   %s\n' "${BOLD}${GREEN}[3]${RESET} ${BOLD}Tech Commons Dell desktops${RESET}"
	printf '   %s\n' "${BOLD}${GREEN}[4]${RESET} ${BOLD}Tech Commons Dell print kiosk laptops${RESET}"
	printf '   %s\n' "${BOLD}${GREEN}[5]${RESET} ${BOLD}Class Tech Dell desktops${RESET}"
	printf '   %s\n' "${BOLD}${GREEN}[6]${RESET} ${BOLD}SHRL Dell desktops${RESET}"
	printf '   %s\n' "${BOLD}${GREEN}[7]${RESET} ${BOLD}Ubuntu Desktop${RESET}"
	read -n1 -p "${BOLD}Enter [1-7]:${RESET} " CLIENTTYPE
	printf '\n'
	case $CLIENTTYPE in
	1)
	cloneImgName='TechCommons-HP-LaptopsLZ4'
	;;
	2)
	cloneImgName='TechCommons-Dell-Laptops'
	;;
	3)
	cloneImgName='TechCommons-Dell-Desktops'
	;;
	4)
	cloneImgName='TechCommons-Dell-HelpDesk'
	;;
	5)
	cloneImgName='ClassTech-Dell-Desktops'
	;;
	6)
	cloneImgName='SHRL-Dell-Desktops'
	;;
	7)
	cloneImgName='Ubuntu-Desktop'
	;;
	*)
	clientselect_Clone
	;;
	esac
}



function execute_Clone {
	/sbin/uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "clone_image_name" --value "${cloneImgName}" --post
	printf "%s" "job_queue|${tagNum}|job_status|Cloning ${cloneImgName} -> ${CLIENTDISK} ($cloneMode)" | /opt/uit-toolbox/parse
	resetUsageData
	start_time=$SECONDS
	linuxServer="UIT_CLIENT_DB_HOST"
	linuxDNS="UIT_SERVER_HOSTNAME"
	umount /home/partimag 2>/dev/null
	mkdir -p /home/partimag
	/sbin/uit-cli --serial "${systemSerial}" --tag "${tagNum}" --key "delete_all_os_info" --delete
	if [[ $cloneMode == "restoredisk" ]]; then
		mount -t nfs -o ro ${linuxServer}:/srv/nfs/uit-toolbox/${linuxPath} /home/partimag
		footer
		reset
		sleep 1
		/usr/sbin/ocs-sr --language en_US.UTF-8 --postaction command --user-mode beginner \
			--skip-set-netboot-first --change-geometry auto --load-geometry-from-edd \
			-k1 --skip-check-restorable-r ${cloneMode} ${cloneImgName} ${CLIENTDISK}
	fi
	if [[ $cloneMode == "savedisk" ]]; then
		mount -t nfs ${linuxServer}:/srv/nfs/uit-toolbox/${linuxPath} /home/partimag
		footer
		reset
		sleep 1
		/usr/sbin/ocs-sr --language en_US.UTF-8 --postaction command --user-mode beginner \
			--skip-enc-ocs-img --skip-fsck-src-part --use-partclone -z8 ${cloneMode} ${cloneImgName} ${CLIENTDISK}
	fi
	cloneElapsed=$(( SECONDS - start_time))
	/sbin/uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key clone_job_duration --value ${cloneElapsed} --post
	umount /home/partimag 2>/dev/null
	return
}



function execute_Shred {
	/sbin/uit-cli --serial "${systemSerial}" --tag "${tagNum}" --key "delete_all_os_info" --delete
	if [[ $APPSELECT == "EC" || $APPSELECT == "E" ]]; then
		start_time=$SECONDS
		if [[ $shredMode == 'nist' ]]; then
			nistMode_Shred
		fi

		if [[ $shredMode == 'zero' ]]; then
			zeroMode_Shred
		fi

		if [[ $shredMode == 'dod' ]]; then
			dodMode_Shred
		fi

		if [[ $shredMode == 'rcmp' ]]; then
			rcmpMode_Shred
		fi
	
		if [[ $shredMode == 'gutmann' ]]; then
			gutmann
		fi
	
		if [[ $shredMode == 'schneier' ]]; then
			schneierMode_Shred
		fi
	
		if [[ $shredMode == 'verify' ]]; then
			verifyMode_Shred
		fi

		if [[ $shredMode == 'unlock' ]]; then
			unlockMode_Shred
		fi
		shredElapsed=$(( SECONDS - start_time ))
		/sbin/uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key erase_job_duration --value ${shredElapsed} --post
	fi
	return
}



function execute {
	resetUsageData
	/sbin/uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "job_start_time" --value "$(date --iso-8601=seconds)" --post
	printf "%s" "job_queue|${tagNum}|job_queued|TRUE" | /opt/uit-toolbox/parse
	printf "%s" "job_queue|${tagNum}|job_active|TRUE" | /opt/uit-toolbox/parse

	###CPU Info
	for i in $(find /sys/class/hwmon/ -mindepth 1); do
    type=$(cat ${i}/name)
    if [[ $type == "coretemp" ]]; then
			cpuTemp=$(cat ${i}/temp1_input)
			printf "%s" "general|avg_cpu_temp|${cpuTemp}|${UUID}" | /opt/uit-toolbox/parse
		fi
	done

	if [[ $cloneMode == "savedisk" && ($APPSELECT == "E" || $APPSELECT == "EC") ]]; then
		printf "%s" "job_queue|${tagNum}|job_status|fail - Can't erase master image" | /opt/uit-toolbox/parse
		read -t 10 -p "${BOLD}Cannot erase device and save its image.${RESET}"
		pkill --terminal tty1
	fi

	if [[ $APPSELECT == "EC" ]]; then
		if [[ -z $cloneMode ]]; then
			clientselect_Clone
		fi
		if [[ $jobName != "hpEraseAndClone" ]]; then
			printf "%s" "job_queue|${tagNum}|job_name|generic-erase+clone" | /opt/uit-toolbox/parse
		fi
		basicEraseMode_Shred
		# /sbin/uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "clone_mode" --value "${cloneMode}" --post
		/sbin/uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "erase_mode" --value "${shredMode}" --post

		start_shred=$SECONDS
		execute_Shred
		shredJobDuration=$((SECONDS - start_shred))
		printf "%s" "api_post|${tagNum}|health_erase_duration|${shredJobDuration}|${UUID}" | /opt/uit-toolbox/parse

		start_clone=$SECONDS
		execute_Clone
		cloneJobDuration=$((SECONDS - start_clone))
		printf "%s" "api_post|${tagNum}|health_clone_duration|${cloneJobDuration}|${UUID}" | /opt/uit-toolbox/parse

	elif [[ $APPSELECT == "E" ]]; then
		if [[ -z $shredMode ]]; then
			advEraseMode_Shred
		else
			basicEraseMode_Shred
		fi
		if [[ $jobName != "nvmeErase" ]]; then
			printf "%s" "job_queue|${tagNum}|job_name|generic-erase" | /opt/uit-toolbox/parse
		fi
		/sbin/uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "erase_mode" --value "${shredMode}" --post
		start_shred=$SECONDS
		execute_Shred
		shredJobDuration=$((SECONDS - start_shred))
		printf "%s" "api_post|${tagNum}|health_erase_duration|${shredJobDuration}|${UUID}" | /opt/uit-toolbox/parse
	elif [[ $APPSELECT == "C" ]]; then
		if [[ -z $cloneMode ]]; then
			clientselect_Clone
		fi
		if [[ $jobName != "hpCloneOnly" ]]; then
			printf "%s" "job_queue|${tagNum}|job_name|generic-clone" | /opt/uit-toolbox/parse
		fi
		start_clone=$SECONDS
		execute_Clone
		cloneJobDuration=$((SECONDS - start_clone))
		printf "%s" "api_post|${tagNum}|health_clone_duration|${cloneJobDuration}|${UUID}" | /opt/uit-toolbox/parse
	else
		printf "%s" "job_queue|${tagNum}|job_queued|FALSE" | /opt/uit-toolbox/parse
		printf "%s" "api_post|${tagNum}|job_queued_at|clear|${UUID}" | /opt/uit-toolbox/parse
		printf "%s" "job_queue|${tagNum}|job_active|FALSE" | /opt/uit-toolbox/parse
		printf "%s" "job_queue|${tagNum}|job_name|" | /opt/uit-toolbox/parse
		printf "%s" "job_queue|${tagNum}|job_status|fail - Invalid application selected" | /opt/uit-toolbox/parse
		read -t 10 -p "${BOLD}${RED}Error - Invalid application selected.${RESET}"
		pkill --terminal tty1
	fi

}


function totaltime {
	totalElapsed=$(printf "%s" $(( (shredElapsed + cloneElapsed) / 60 )))
}


function terminate {
	printf "%s" "job_queue|${tagNum}|job_name|" | /opt/uit-toolbox/parse
	printf "%s" "job_queue|${tagNum}|job_queued|FALSE" | /opt/uit-toolbox/parse
	printf "%s" "api_post|${tagNum}|job_queued_at|clear|${UUID}" | /opt/uit-toolbox/parse
	printf "%s" "job_queue|${tagNum}|job_active|FALSE" | /opt/uit-toolbox/parse
	printf "%s" "job_queue|${tagNum}|job_status|Waiting for job" | /opt/uit-toolbox/parse
	printf "%s" "system-stats|cpu|${UUID}" | /opt/uit-toolbox/parse
	printf "%s" "system-stats|network|${UUID}" | /opt/uit-toolbox/parse
	resetUsageData
	
	footer
	totaltime

	collectDiskData

	for i in $(ps | grep 'uit-cpu' | awk '{ print $1 }'); do kill "${i}" 2>/dev/null; done
	for i in $(ps | grep 'uit-network' | awk '{ print $1 }'); do kill "${i}" 2>/dev/null; done


	imgUpdate=$(printf "%s" "SELECT time AS result FROM jobstats WHERE clone_master = TRUE ORDER BY time DESC LIMIT 1" | /opt/uit-toolbox/select)
	imgUpdate=${imgUpdate::10}

	cloneNumToday=$(printf "%s" "SELECT COUNT(tagnumber) AS result FROM jobstats WHERE clone_completed = TRUE AND time > '$(date --iso) 00:00:00.000'" | /opt/uit-toolbox/select)

	eraseNumToday=$(printf "%s" "SELECT COUNT(tagnumber) AS result FROM jobstats WHERE erase_completed = TRUE AND time > '$(date --iso) 00:00:00.000'" | /opt/uit-toolbox/select)

	clientCloneTotal=$(printf "%s" "SELECT COUNT(tagnumber) AS result FROM jobstats WHERE clone_completed = TRUE AND tagnumber = '${tagNum}'" | /opt/uit-toolbox/select)

	jobsToday=$(( cloneNumToday + eraseNumToday ))

	if [[ $APPSELECT == "C" || $APPSELECT == "EC" ]]; then
		if [[ $cloneMode == "restoredisk" ]]; then

			if [[ $cloneMode == "restoredisk" && $APPSELECT == "EC" ]]; then
				terminateAction="Erased and cloned"
			fi

			if [[ $cloneMode == "restoredisk" && $APPSELECT == "C" ]]; then
				terminateAction="Cloned"
			fi

			/sbin/uit-cli --tag "${tagNum}" --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "clone_completed" --value "TRUE" --post
			printf "%s" "api_post|${tagNum}|health_clone_completed|1|${UUID}" | /opt/uit-toolbox/parse

			if [[ $APPSELECT == "EC" ]]; then
				/sbin/uit-cli --tag "${tagNum}" --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "erase_completed" --value "TRUE" --post
				printf "%s" "api_post|${tagNum}|health_erase_completed|1|${UUID}" | /opt/uit-toolbox/parse
			fi

			terminateMessage=$(printf '%s\n' "Tag#: ${tagNum}"
			printf '%s\n' "MAC: ${etherAddr}"
			printf '%s\n' "Action: ${terminateAction}"
			printf '%s\n' "Total time taken: ${totalElapsed} minutes"
			printf '%s\n' "Server: \"${linuxDNS}\""
			printf '%s\n' "Image: \"${cloneImgName}\""
			printf '%s\n' "Total jobs today: ${jobsToday}"
			)
		fi
		if [[ $cloneMode == "savedisk" ]]; then
			/sbin/uit-cli --tag "${tagNum}" --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "clone_master" --value "TRUE" --post
			/sbin/uit-cli --tag "${tagNum}" --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "clone_completed" --value "TRUE" --post
			printf "%s" "api_post|${tagNum}|health_clone_completed|1|${UUID}" | /opt/uit-toolbox/parse

			terminateMessage=$(printf '%s\n' "Tag#: ${tagNum}"
			printf '%s\n' "MAC: ${etherAddr}"
			printf '%s\n' "Action: ${terminateAction}"
			printf '%s\n' "Total time taken: ${totalElapsed} minutes"
			printf '%s\n' "Server: \"${linuxDNS}\""
			printf '%s\n' "Image: \"${cloneImgName}\""
			printf '%s\n' "Total jobs today: ${jobsToday}"
			)
		fi
	fi
	

	if [[ $APPSELECT == "E" ]]; then
				/sbin/uit-cli --tag "${tagNum}" --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "erase_completed" --value "TRUE" --post
		printf "%s" "api_post|${tagNum}|health_erase_completed|1|${UUID}" | /opt/uit-toolbox/parse

		terminateAction="erased"

		terminateMessage=$(printf '%s\n' "Tag#: ${tagNum}"
		printf '%s\n' "MAC: ${etherAddr}"
		printf '%s\n' "Action: ${terminateAction}"
		printf '%s\n' "Total time taken: ${totalElapsed} minutes"
		printf '%s\n' "Total jobs today: ${jobsToday}"
		)		
	fi

	if [[ $mainMenuOpt != 0 ]]; then
		/usr/bin/play /root/oven.mp3 &> /dev/null
	fi
	footer
	printf '%s\n' "${BOLD}Process has finished!${RESET}"
	printf '\n'
	printf '\n'
	printf '%s\n' "${terminateMessage}"
	printf '\n'
	printf '\n'
	read -p "${BOLD}Process has finished. Press ${GREEN}Enter${RESET}${BOLD} to shutdown...${RESET} "
	poweroff
}

function resetForClientRestart {
	printf "%s" "job_queue|${tagNum}|job_name|" | /opt/uit-toolbox/parse
	printf "%s" "job_queue|${tagNum}|job_queued|FALSE" | /opt/uit-toolbox/parse
	printf "%s" "api_post|${tagNum}|job_queued_at|clear|${UUID}" | /opt/uit-toolbox/parse
	printf "%s" "job_queue|${tagNum}|job_active|FALSE" | /opt/uit-toolbox/parse
	for i in $(ps | grep 'uit-cpu' | awk '{ print $1 }'); do kill "${i}" 2>/dev/null; done
	for i in $(ps | grep 'uit-network' | awk '{ print $1 }'); do kill "${i}" 2>/dev/null; done
	for i in $(ps | grep 'uit-sql' | awk '{ print $1 }'); do kill "${i}" 2>/dev/null; done
	for i in $(ps | grep 'uit-screenshot' | awk '{ print $1 }'); do kill "${i}" 2>/dev/null; done
	dpkg --purge uit-toolbox-client
	rm -r /root/uit-toolbox-client*
	rm -r /root/.ssh/known_hosts*
	resetUsageData
	pkill --terminal tty1
}

function autodetectClient {
	footer
	# if [[ $(printf "%s" "${systemManufacturer}" | grep -i "dell") ]]; then
	# 	systemManufacturerFormatted="dell"
	# 	cloneImgName='TechCommons-Dell-Laptops'
	# 	elif [[ $(printf "%s" "${systemManufacturer}" | grep -i "hp") ]]; then
	# 		systemManufacturerFormatted="hp"
	# 		cloneImgName='TechCommons-HP-LaptopsLZ4'
	# 	elif [[ $(printf "%s" "${systemManufacturer}" | grep -i "hewlett") ]]; then
	# 		systemManufacturerFormatted="hp"
	# 		cloneImgName='TechCommons-HP-LaptopsLZ4'
	# 	else
	# 		systemManufacturerFormatted="unknown"
	# 		cloneImgName='TechCommons-HP-LaptopsLZ4'
	# fi

	systemModel=$(dmidecode --string system-product-name)
	if [[ -z $systemModel ]]; then
		systemModel=$(cat /sys/class/dmi/id/product_name)
	fi

	cloneImgName=$(uit-cli --key "disk_image_name" --value "$systemModel" --get | jq -r '.disk_image_name')
	if [[ -z $cloneImgName || $cloneImgName == "null" ]]; then
		cloneImgName="TechCommons-HP-LaptopsLZ4"
	fi

	if [[ $(printf "%s" "${chassisType}" | grep -i "notebook") ]]; then
		chassisType="notebook"
		elif [[ $(printf "%s" "${chassisType}" | grep -i "desktop") ]]; then
			chassisType="desktop"
		else
			chassisType="unknown"
	fi

	while true; do
		ACTION=""
		CLIENTDISK=""
		cloneMode=""
		header
		printf '\n'
		printf '\n'

		sql=$(printf "%s" "SELECT tagnumber AS result FROM job_queue WHERE tagnumber = '${tagNum}' AND job_status NOT like 'fail%'" | /opt/uit-toolbox/select)
		if [[ $sql == $tagNum ]]; then
			printf "%s" "job_queue|${tagNum}|job_status|Waiting for job" | /opt/uit-toolbox/parse
		fi

		unattended="true"

		fetchJobQueueData
		if [[ $jobName != "" ]]; then
			printf "%s" "job_queue|${tagNum}|job_queued|TRUE" | /opt/uit-toolbox/parse
			printf "%s" "api_post|${tagNum}|job_queued_at|now|${UUID}" | /opt/uit-toolbox/parse
			
			tput cuu1
			tput el
			while true; do
				header
				printf "\n\n"
				tput cuu1
				tput el
				fetchJobQueueData
				if [[ $jobName == "" ]]; then
					break
				fi
				if [[ $jobQueuedPosition -eq 0 || $jobQueuedPosition -eq 1 ]]; then
					sleep 1
					okay_to_go=$(printf '%s' "api_get|job_queue_position|tagnumber|${tagNum}" | /opt/uit-toolbox/parse)
					if [[ $okay_to_go -le 1 ]]; then
						printf "%s" "job_queue|${tagNum}|job_queued|TRUE" | /opt/uit-toolbox/parse
						printf "%s" "job_queue|${tagNum}|job_active|TRUE" | /opt/uit-toolbox/parse
						break
					fi
				fi
				printf '%s\n' "	${BOLD}Tagnumber ${tagNum} (${systemSerial}) is scheduled for ${jobNameFormatted} and is ${jobQueuedPosition} in queue. Press ${BOLD}${GREEN}'q' ${RESET}${BOLD}to exit.${RESET}"
				printf "%s" "job_queue|${tagNum}|job_status|Scheduled for ${jobNameFormatted}, ${jobQueuedPosition} in queue." | /opt/uit-toolbox/parse
				read -t 3 -N 1 input
				if [[ $input = "q" ]] || [[ $input = "Q" ]]; then
					resetUsageData
					printf "%s" "job_queue|${tagNum}|job_name|" | /opt/uit-toolbox/parse
					printf "%s" "job_queue|${tagNum}|job_queued|FALSE" | /opt/uit-toolbox/parse
					printf "%s" "api_post|${tagNum}|job_queued_at|clear|${UUID}" | /opt/uit-toolbox/parse
					printf "%s" "job_queue|${tagNum}|job_active|FALSE" | /opt/uit-toolbox/parse
					pkill --terminal tty1
				fi
			done
			if [[ $jobName == "update" ]]; then
				findIdentityInDB
				printf "%s" "job_queue|${tagNum}|job_status|Updating..." | /opt/uit-toolbox/parse
				collectSystemData
				if [[ -f /root/uit-toolbox-client.deb ]]; then
					rm /root/uit-toolbox-client.deb
				fi
				printf "%s" "job_queue|${tagNum}|job_status|Downloading update..." | /opt/uit-toolbox/parse
        curl --silent --show-error 'http://10.0.0.1:8080/client/pkg/uit-toolbox-client.deb' --output /root/uit-toolbox-client.deb
				while [[ ! -f /root/uit-toolbox-client.deb ]]; do
					printf "%s" "job_queue|${tagNum}|job_status|Retrying download..." | /opt/uit-toolbox/parse
					echo "Package download failed, retrying download..."
					curl --silent --show-error 'http://10.0.0.1:8080/client/pkg/uit-toolbox-client.deb' --output /root/uit-toolbox-client.deb
					sleep 1
				done
				dpkg --install /root/uit-toolbox-client.deb &>/dev/null
				resetForClientRestart
			elif [[ $jobName == "findmy" ]]; then
				printf "%s" "job_queue|${tagNum}|job_status|Playing sound" | /opt/uit-toolbox/parse
				play /root/findmy1.mp3 &> /dev/null
				resetForClientRestart
			elif [[ $jobName == "hpEraseAndClone" ]]; then
				findIdentityInDB
				collectSystemData
				printf "%s" "job_queue|${tagNum}|job_status|Starting Erase + Clone job (HP)" | /opt/uit-toolbox/parse
				APPSELECT="EC"
				ACTION="erase and clone"
				if [[ /dev/nvme0n1 ]]; then
					CLIENTDISK='nvme0n1'
				else
					printf "%s" "job_queue|${tagNum}|job_status|fail - Disk doesn't exist" | /opt/uit-toolbox/parse
					autodetectClient
				fi
				/sbin/uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "disk_name" --value "${CLIENTDISK}" --post
				cloneMode="restoredisk"
				shredMode="autodetect"
				RMODE="Autodetect"
				/sbin/uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "erase_mode" --value "${RMODE}" --post
				linuxServer="UIT_CLIENT_DB_HOST"
				linuxDNS="UIT_SERVER_HOSTNAME"
				footer
				putDeviceToSleep
				checkNetwork
				footer
				execute
				totaltime
				/sbin/uit-cli --tag "${tagNum}" --serial "${systemSerial}" --uuid "${UUID}" --key clone_completed --value "TRUE" --post
				printf "%s" "api_post|${tagNum}|health_clone_completed|1|${UUID}" | /opt/uit-toolbox/parse
				/sbin/uit-cli --tag "${tagNum}" --serial "${systemSerial}" --uuid "${UUID}" --key erase_completed --value "TRUE" --post
				printf "%s" "api_post|${tagNum}|health_erase_completed|1|${UUID}" | /opt/uit-toolbox/parse
				printf "%s" "system-stats|cpu|${UUID}" | /opt/uit-toolbox/parse
				printf "%s" "system-stats|network|${UUID}" | /opt/uit-toolbox/parse
				resetForClientRestart
			elif [[ $jobName == "hpCloneOnly" ]]; then
				findIdentityInDB
				collectSystemData
				printf "%s" "job_queue|${tagNum}|job_status|Starting Clone only job (HP)" | /opt/uit-toolbox/parse
				APPSELECT="C"
				ACTION="clone"
				if [[ /dev/nvme0n1 ]]; then
					CLIENTDISK='nvme0n1'
				else
					printf "%s" "job_queue|${tagNum}|job_status|fail - disk doesn't exist" | /opt/uit-toolbox/parse
					autodetectClient
				fi
				/sbin/uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "disk_name" --value "${CLIENTDISK}" --post
				cloneMode="restoredisk"
				linuxServer="UIT_CLIENT_DB_HOST"
				linuxDNS="UIT_SERVER_HOSTNAME"
				footer
				putDeviceToSleep
				checkNetwork
				footer
				execute
				totaltime
				/sbin/uit-cli --tag "${tagNum}" --serial "${systemSerial}" --uuid "${UUID}" --key clone_completed --value "TRUE" --post
				printf "%s" "api_post|${tagNum}|health_clone_completed|1|${UUID}" | /opt/uit-toolbox/parse
				printf "%s" "system-stats|cpu|${UUID}" | /opt/uit-toolbox/parse
				printf "%s" "system-stats|network|${UUID}" | /opt/uit-toolbox/parse
				resetForClientRestart
			elif [[ $jobName == "nvmeErase" ]]; then
				findIdentityInDB
				collectSystemData
				if [[ /dev/nvme0n1 ]]; then
					CLIENTDISK='nvme0n1'
				else
					printf "%s" "job_queue|${tagNum}|job_status|fail - disk doesn't exist" | /opt/uit-toolbox/parse
					autodetectClient
				fi
				/sbin/uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "disk_name" --value "${CLIENTDISK}" --post
				printf "%s" "job_queue|${tagNum}|job_status|Starting NVME Erase job (${CLIENTDISK})" | /opt/uit-toolbox/parse
				vrfySections="1000"
				writeSections="1000"
				PCNTOFSECTOR='10'
				CHAR='0'
				APPSELECT="E"
				ACTION="erase"
				shredMode="autodetect"
				RMODE="Autodetect"
				/sbin/uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "erase_mode" --value "${RMODE}" --post
				footer
				putDeviceToSleep
				checkNetwork
				footer
				execute
				totaltime
				/sbin/uit-cli --tag "${tagNum}" --serial "${systemSerial}" --uuid "${UUID}" --key erase_completed --value "TRUE" --post
				printf "%s" "api_post|${tagNum}|health_erase_completed|1|${UUID}" | /opt/uit-toolbox/parse
				printf "%s" "system-stats|cpu|${UUID}" | /opt/uit-toolbox/parse
				printf "%s" "system-stats|network|${UUID}" | /opt/uit-toolbox/parse
				resetForClientRestart
			elif [[ $jobName == "nvmeVerify" ]]; then
				findIdentityInDB
				collectSystemData
				printf "%s" "job_queue|${tagNum}|job_status|Starting Verify job (${CLIENTDISK})" | /opt/uit-toolbox/parse
				vrfySections=""
				writeSections=""
				PCNTOFSECTOR='10'
				CHAR='0'
				APPSELECT="E"
				ACTION="erase"
				if [[ /dev/nvme0n1 ]]; then
					CLIENTDISK='nvme0n1'
				else
					printf "%s" "job_queue|${tagNum}|job_status|fail - disk doesn't exist" | /opt/uit-toolbox/parse
					autodetectClient
				fi
				/sbin/uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "disk_name" --value "${CLIENTDISK}" --post
				shredMode="verify"
				RMODE="Verify Mode"
				/sbin/uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "erase_mode" --value "${RMODE}" --post
				footer
				putDeviceToSleep
				checkNetwork
				footer
				execute
				totaltime
				/sbin/uit-cli --tag "${tagNum}" --serial "${systemSerial}" --uuid "${UUID}" --key "erase_completed" --value "TRUE" --post
				printf "%s" "api_post|${tagNum}|health_erase_completed|1|${UUID}" | /opt/uit-toolbox/parse
				printf "%s" "system-stats|cpu|${UUID}" | /opt/uit-toolbox/parse
				printf "%s" "system-stats|network|${UUID}" | /opt/uit-toolbox/parse
				resetForClientRestart
			elif [[ $jobName == "shutdown" ]]; then
				printf "%s" "job_queue|${tagNum}|job_status|Shutting down" | /opt/uit-toolbox/parse
				printf "%s" "job_queue|${tagNum}|job_queued|FALSE" | /opt/uit-toolbox/parse
				printf "%s" "api_post|${tagNum}|job_queued_at|clear|${UUID}" | /opt/uit-toolbox/parse
				printf "%s" "job_queue|${tagNum}|job_active|FALSE" | /opt/uit-toolbox/parse
				printf "%s" "job_queue|${tagNum}|job_name|" | /opt/uit-toolbox/parse
				poweroff				
			elif [[ $jobName == "fail-test" ]]; then
				printf "%s" "job_queue|${tagNum}|job_status|fail - test" | /opt/uit-toolbox/parse
				resetForClientRestart
			fi
		else
			tput cuu1
			tput el
			printf '%s\n' "	${BOLD}Tagnumber ${tagNum} (${systemSerial}) has no scheduled jobs right now. Press ${BOLD}${GREEN}'q' ${RESET}${BOLD}to continue.${RESET}"
			read -t 3 -N 1 input
			if [[ $input = "q" ]] || [[ $input = "Q" ]]; then
				break
			fi
		fi
	done

	unattended="false"
	header
	printf '%s\n' "${BOLD}${BLUE}Autodetect mode${RESET}${BOLD} will destroy all data on this laptop and image it."
	printf '\n'
	printf '%s\n' "------------------------------"
	printf '%s\n' "${BOLD}Select mode:${RESET}"
	printf '   %s\n' "${BOLD}${GREEN}[1]${RESET} ${BOLD}Autodetect${RESET}"
	printf '   %s\n' "${BOLD}${GREEN}[2]${RESET} ${BOLD}Manual${RESET}"
	read -n 1 -p "${BOLD}Enter [1,2]:${RESET} " input

	if [[ $input == "1" ]]; then
		if [[ $systemManufacturerFormatted == "hp" && $chassisType == "notebook" && $diskType == "nvme" ]]; then
			mainMenuOpt="1"
		elif [[ $systemManufacturerFormatted == "dell" && $chassisType == "notebook" && $diskType == "nvme" ]]; then
			mainMenuOpt="2"
		else
			printf '\n'
			printf '%s\n' "${BOLD}${RED}Not enough info for autodetect.${RESET}"
			sleep 0.5
			manualClient
		fi
		printf '\n'
		printf '%s\n' "------------------------------"
		printf '%s\n' "${BOLD}Is this information corect?${RESET}"
		printf '\n'
		printf '%s\n' "${BOLD}${BLUE}System Manufacturer${RESET}${BOLD}: ${systemManufacturerFormatted}${RESET}"
		printf '%s\n' "${BOLD}${BLUE}Chassis Type${RESET}${BOLD}: ${chassisType}${RESET}"
		printf '%s\n' "${BOLD}${BLUE}Disk type${RESET}${BOLD}: ${DISK}${RESET}"
		printf '\n'
		printf '%s\n' "${BOLD}${GREEN}[1]${RESET} ${BOLD}Yes, it is correct${RESET}"
		printf '%s\n' "${BOLD}${GREEN}[2]${RESET} ${BOLD}No, start over${RESET}"
		read -n 1 -p "${BOLD}Please enter [1,2]:${RESET} " input
		if [[ $input == "1" ]]; then
				return
			else
				autodetectClient
		fi
		else
			manualClient
	fi
}


function main {
	tput reset
	findIdentityInDB
	collectSystemData
	printf "%s" "api_post|${tagNum}|last_hardware_check|${CURRENT_TIME}|${UUID}" | /opt/uit-toolbox/parse
	tput reset
	autodetectClient
	if [[ $mainMenuOpt == "1" ]]; then
		APPSELECT="EC"
		ACTION="erase and clone"
		if [[ /dev/nvme0n1 ]]; then
			CLIENTDISK='nvme0n1'
		else
			diskSelect
		fi
		
		/sbin/uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "disk_name" --value "${CLIENTDISK}" --post

		cloneMode="restoredisk"
		cloneImgName="TechCommons-HP-LaptopsLZ4"
		shredMode="autodetect"
		RMODE="autodetect"
		/sbin/uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "erase_mode" --value "${RMODE}" --post
		linuxServer="UIT_CLIENT_DB_HOST"
		linuxDNS="UIT_SERVER_HOSTNAME"
		powerWarning
		execute
	elif [[ $mainMenuOpt == "2" ]]; then
		APPSELECT="EC"
		ACTION="erase and clone"
		if [[ /dev/nvme0n1 ]]; then
			CLIENTDISK='nvme0n1'
		else
			diskSelect
		fi
			
		/sbin/uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "disk_name" --value "${CLIENTDISK}" --post
		cloneMode="restoredisk"
		cloneImgName="TechCommons-Dell-Laptops"
		shredMode="autodetect"
		RMODE="autodetect"
		/sbin/uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "erase_mode" --value "${RMODE}" --post
		linuxServer="UIT_CLIENT_DB_HOST"
		linuxDNS="UIT_SERVER_HOSTNAME"
		powerWarning
		execute
	elif [[ $mainMenuOpt == "3" ]]; then
		APPSELECT="E"
		ACTION="erase"
		diskSelect
			
		/sbin/uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "disk_name" --value "${CLIENTDISK}" --post
		shredMode="autodetect"
		RMODE="autodetect"
		/sbin/uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "erase_mode" --value "${RMODE}" --post
		powerWarning
		execute
	elif [[ $mainMenuOpt == "9" ]]; then
		appSelect
		if [[ $APPSELECT != "battery" ]]; then
			diskSelect
			execute
		else
			appSelect
		fi
	elif [[ $mainMenuOpt == "0" ]]; then
		:
	else
		pkill --terminal tty1
	fi
	if [[ $unattended == "false" ]]; then
		printf "%s" "job_queue|${tagNum}|job_queued|FALSE" | /opt/uit-toolbox/parse
		printf "%s" "api_post|${tagNum}|job_queued_at|clear|${UUID}" | /opt/uit-toolbox/parse
		printf "%s" "job_queue|${tagNum}|job_active|FALSE" | /opt/uit-toolbox/parse
		terminate
	fi
}

main