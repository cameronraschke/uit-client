#!/bin/bash
SSD_REGEX='sd.*'
NVME_REGEX='nvme.*'
SCSI_REGEX='hd.*'
RED=$(tput setaf 1)
GREEN=$(tput setaf 2)
BLUE=$(tput setaf 4)
BOLD=$(tput bold)
DIM=$(tput dim)
RESET=$(tput sgr0)
cloneElapsed="0"
shredElapsed="0"
UIT_CLIENT_DRY_RUN="${UIT_CLIENT_DRY_RUN:-false}"

for i in $(ps | grep 'uit-cpu' | awk '{ print $1 }'); do kill "${i}" 2>/dev/null; done
for i in $(ps | grep 'uit-network' | awk '{ print $1 }'); do kill "${i}" 2>/dev/null; done
for i in $(ps | grep 'uit-sql' | awk '{ print $1 }'); do kill "${i}" 2>/dev/null; done
for i in $(ps | grep 'uit-screenshot' | awk '{ print $1 }'); do kill "${i}" 2>/dev/null; done

function resetUsageData {
	printf "%s" '0' > /root/client_app_uptime
	printf "%s" '0' > /tmp/cpu-usage.txt
	printf "%s" '0' > /tmp/network-usage.txt
}

function dryRunEnabled {
	case "${UIT_CLIENT_DRY_RUN}" in
		1|[Tt][Rr][Uu][Ee]|[Yy][Ee][Ss]|[Oo][Nn])
			return 0
			;;
		*)
			return 1
			;;
	esac
}

function dryRunLog {
	printf '%s\n' "[dry-run] $*"
}

function dryRunSectionLog {
	local action="$1"
	local index="$2"
	local total="$3"
	local sectorMin="$4"
	local sectorMax="$5"
	local sectorDiff="$6"
	local count="$7"
	local startSector="$8"
	local bs="$9"
	local sectionLast sampleLast

	sectionLast=$((sectorMax - 1))
	sampleLast=$((startSector + count - 1))
	dryRunLog "${action} section ${index}/${total}: range=${sectorMin}-${sectionLast} sectors=${sectorDiff} bytes=$((sectorDiff * bs)) sample=${startSector}-${sampleLast} sample_sectors=${count} sample_bytes=$((count * bs)) percent=${PCNTOFSECTOR}"
}

function patternToHex_Shred {
	local pattern="$1"

	if [[ $pattern =~ ^[01]{8}$ ]]; then
		printf '%02x' "$((2#${pattern}))"
		return 0
	fi

	if [[ $pattern =~ ^[[:xdigit:]]$ ]]; then
		printf '%s%s' "${pattern}" "${pattern}"
		return 0
	fi

	if [[ $pattern =~ ^([[:xdigit:]]{2})+$ ]]; then
		printf '%s' "${pattern}"
		return 0
	fi

	printf '%s' "${pattern}" | xxd -p -c 256 | tr -d '\n'
}

function emitHexPattern_Shred {
	local hexPattern="$1"

	perl -e 'my $hex = shift; my $pattern = pack("H*", $hex); die "empty pattern\n" unless length $pattern; $| = 1; my $repeat = int(65536 / length($pattern)); $repeat = 1 if $repeat < 1; my $chunk = $pattern x $repeat; while (1) { print $chunk; }' -- "${hexPattern}"
}

function verifyHexPatternStream_Shred {
	local hexPattern="$1"

	perl -e 'use bytes; my $hex = shift; my $pattern = pack("H*", $hex); exit 1 unless length $pattern; my $len = length $pattern; my @allowed; while (read(STDIN, my $buffer, 65536)) { for my $byte (split //, $buffer) { if (!@allowed) { @allowed = grep { substr($pattern, $_, 1) eq $byte } 0 .. ($len - 1); exit 1 unless @allowed; next; } @allowed = grep { substr($pattern, (($_ + 1) % $len), 1) eq $byte } @allowed; exit 1 unless @allowed; } } exit(@allowed ? 0 : 1);' -- "${hexPattern}"
}

function expectedPatternHex_Shred {
	printf '%s' "$(patternToHex_Shred "${CHAR}")"
}

function emitSource_Shred {
	case "${WMODE}" in
		zero)
			cat /dev/zero
			;;
		random)
			cat /dev/urandom
			;;
		randBit_Shred)
			emitHexPattern_Shred "$(patternToHex_Shred "${RANDBIT}")"
			;;
		randPattern_Shred)
			emitHexPattern_Shred "$(patternToHex_Shred "${RANDPATTERN}")"
			;;
		char)
			emitHexPattern_Shred "$(patternToHex_Shred "${CHAR}")"
			;;
		*)
			return 1
			;;
	esac
}

umount /home/partimag 2>/dev/null

printf '\n'
printf '%s\n' "${BOLD}Changing font...${RESET}"
setupcon
DefaultFontLines=$(tput lines)
/usr/bin/setfont /usr/share/consolefonts/Uni3-Terminus32x16.psf.gz &>/dev/null
XLFontLines=$(tput lines)
/usr/bin/setfont /usr/share/consolefonts/Uni3-Terminus28x14.psf.gz &>/dev/null
LFontLines=$(tput lines)
/usr/bin/setfont /usr/share/consolefonts/Uni3-Terminus24x12.psf.gz &>/dev/null
MFontLines=$(tput lines)
/usr/bin/setfont /usr/share/consolefonts/Uni3-Terminus22x11.psf.gz &>/dev/null
SFontLines=$(tput lines)
/usr/bin/setfont /usr/share/consolefonts/Uni3-Terminus20x10.psf.gz &>/dev/null
XSFontLines=$(tput lines)
/usr/bin/setfont /usr/share/consolefonts/Uni3-Terminus18x10.psf.gz &>/dev/null
XXSFontLines=$(tput lines)

unset fontArr
declare -A fontArr
fontArr["XL"]=$XLFontLines
fontArr["L"]=$LFontLines
fontArr["M"]=$MFontLines
fontArr["S"]=$SFontLines
fontArr["XS"]=$XSFontLines
fontArr["XXS"]=$XXSFontLines

targetRows=33
minDifference=$(( targetRows - DefaultFontLines ))
if [[ $minDifference -lt 0 ]]; then minDifference=$(( -1 * minDifference )); fi
for key in ${!fontArr[@]}; do
	value=${fontArr[${key}]}
	difference=$(( targetRows - value ))
	if [[ difference -lt 0 ]]; then
		difference=$(( -1 * difference ))
	fi

	if [[ $difference -lt $minDifference ]]; then
		minDifference=$difference
		fontValue=$key
	fi
done

if [[ $fontValue == "XL" ]]; then
	/usr/bin/setfont /usr/share/consolefonts/Uni3-Terminus32x16.psf.gz &>/dev/null
elif [[ $fontValue == "L" ]]; then
	/usr/bin/setfont /usr/share/consolefonts/Uni3-Terminus28x14.psf.gz &>/dev/null
elif [[ $fontValue == "M" ]]; then
	/usr/bin/setfont /usr/share/consolefonts/Uni3-Terminus24x12.psf.gz &>/dev/null
elif [[ $fontValue == "S" ]]; then
	/usr/bin/setfont /usr/share/consolefonts/Uni3-Terminus22x11.psf.gz &>/dev/null
elif [[ $fontValue == "XS" ]]; then
	/usr/bin/setfont /usr/share/consolefonts/Uni3-Terminus20x10.psf.gz &>/dev/null
elif [[ $fontValue == "XXS" ]]; then
	/usr/bin/setfont /usr/share/consolefonts/Uni3-Terminus18x10.psf.gz &>/dev/null
fi

printf '%s\n' "${GREEN}Done.${RESET}"

printf '\n'
printf '%s\n' "${BOLD}Changing brightness...${RESET}"
maxBrightness=$(cat /sys/class/backlight/*/max_brightness)
printf "%s" "${maxBrightness}" > /sys/class/backlight/*/brightness 2>/dev/null
printf '%s\n' "${GREEN}Done.${RESET}"

printf '\n'
printf '%s\n' "${BOLD}Configuring networking....${RESET}"
for i in $(ip addr | awk '/state UP/ {print $2}' | sed 's/://g' | grep '^e' | head -n1); do
  	ip addr flush dev ${iface}
  	dhclient -r ${iface}
  	dhclient -4 ${iface}
 done &>/dev/null
 printf '%s\n' "${GREEN}Done.${RESET}"

printf '\n'
printf '%s\n' "${BOLD}Syncing time...${RESET}"
printf '%s\n' "[Time]
NTP=UIT_CLIENT_NTP_HOST" > /etc/systemd/timesyncd.conf

systemctl daemon-reload &>/dev/null
/usr/bin/timedatectl set-timezone 'America/Chicago'
/usr/bin/timedatectl set-ntp true
/usr/bin/timedatectl set-local-rtc false

/usr/bin/chronyc add server UIT_CLIENT_NTP_HOST iburst
/usr/bin/chronyc makestep

while [[ $(echo -n "api_get|server_time" | /opt/uit-toolbox/parse) != $(date --iso-8601=seconds) ]]; do
	echo "Error: time is not synced with server. Retrying..." >&2
	echo "server_time: $(echo -n "api_get|server_time" | /opt/uit-toolbox/parse), local_time: $(date --iso-8601=seconds)" >&2
	sleep 0.5
done
printf '%s\n' "${GREEN}Done.${RESET}"

printf '\n'
printf '%s\n' "${BOLD}Running disk checks....${RESET}"
if [[ -f /root/smartctl-data ]]; then
	rm /root/smartctl-data
fi
for i in $(lsblk -o NAME --nodeps --noheadings --exclude 1,2,7,11); do
	if [[ $(cat /sys/block/${i}/removable) == 0 ]]; then
		smartctl -t short -a /dev/${i} > /root/smartctl-data
	fi
done
printf '%s\n' "${GREEN}Done.${RESET}"


printf '\n'
printf '%s\n' "${BOLD}Configuring audio...${RESET}"
/usr/bin/amixer sset Master 100% &>/dev/null
/usr/bin/amixer set Master unmute &>/dev/null
/usr/bin/amixer sset Speakers 100% &>/dev/null
/usr/sbin/amixer set Speakers unmute &>/dev/null
printf '%s\n' "${GREEN}Done.${RESET}"


if [[ $(dmidecode --string system-product-name) == "Dell Pro Micro QCM1250" ]]; then
	# Issue with Intel Pro NICs on wake up, can't hibernate and wake up w/o NIC issues.
	systemctl mask sleep.target suspend.target hibernate.target hybrid-sleep.target
else
	## Laptops need everything masked when lids are closed, fix later
	systemctl mask sleep.target suspend.target hibernate.target hybrid-sleep.target
fi

	# Check if running kernel is up to date
	for i in $(ls /lib/modules); do
		echo "${i}" | grep -i --quiet "$(uname -r)"
		if [[ ${PIPESTATUS[1]} == "0" ]]; then
			break
		else
			echo "job_queue|${tagNum}|kernel_updated|" | /opt/uit-toolbox/parse
			printf '%s\n' "${RED}Warning: Running kernel is not up to date. Please update the kernel.${RESET}"
			exit 1
		fi
	done

etherAddr=$(for i in $(ip addr | awk '/state UP/ {print $2}' | sed 's/://g' | grep '^e' | head -n1); do cat /sys/class/net/${i}/address 2>/dev/null; done)
netInterfaceName=$(ip addr | awk '/state UP/ {print $2}' | sed 's/://g' | grep '^e' | head -n1)
wifiMac=$(cat /sys/class/ieee80211/phy*/macaddress 2>/dev/null | head -n1)
systemSerial=$(dmidecode --string system-serial-number 2>/dev/null)
if [[ -z $systemSerial ]]; then
	systemSerial=$(cat /sys/class/dmi/id/product_serial)
fi
ipAddr=$(ip addr | grep -C 2 'state UP' | grep 'inet' | grep -oP '10.0.0.[0-9]{1,3}/16' | sed 's/\/16//g')


function fetchJobQueueData {
	jobName=$(printf "%s" "api_get|job_name|tagnumber|${tagNum}" | /opt/uit-toolbox/parse)
	jobNameFormatted=$(printf "%s" "api_get|job_name_formatted|job_name|${jobName}" | /opt/uit-toolbox/parse)
	jobQueuedPosition=$(printf '%s' "api_get|job_queue_position|tagnumber|${tagNum}" | /opt/uit-toolbox/parse)
}

linuxPath="images"

tput reset

function collectDiskData {
		###Disk Data
	for i in $(lsblk -o NAME --nodeps --noheadings --exclude 1,2,7,11); do
		if [[ $(cat /sys/block/${i}/removable) == 1 ]]; then
			continue
		fi
		if [[ -f /root/smartctl-data ]]; then
			rm /root/smartctl-data
		fi
		smartctl -t short -a /dev/${i} > /root/smartctl-data
		# /sbin/uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "disk_name" --value "${i}" --post

		# Disk model
		diskModel=$(cat /sys/class/block/${i}/device/model 2>/dev/null)
		uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "disk_model" --value "${diskModel}" --post

		# Disk Serial
		diskSerial=$(cat /sys/class/block/${i}/device/serial 2>/dev/null)
		uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "disk_serial" --value "${diskSerial}" --post

		# Disk Size
		diskSectorCount=$(cat /sys/class/block/${i}/size 2>/dev/null)
		if [[ -n $diskSectorCount && $diskSectorCount -gt 0 ]]; then
			diskSizeBytes=$(( $diskSectorCount * 512))
			if [[ -n $diskSizeBytes && $diskSizeBytes -gt 1024 ]]; then
				diskSizeKiB=$(( $diskSizeBytes / 1024 ))
			fi
			if [[ -n $diskSizeKiB && $diskSizeKiB -gt 0 ]]; then
				uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "disk_size_kb" --value "${diskSizeKiB}" --post
			fi
		fi

		# Disk Power On Hours
		diskPowerOnHours=$(cat /root/smartctl-data | grep -iP 'Power( |_)On( |_)Hours' | sed 's/[^0-9]//g')
		uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "disk_power_on_hours" --value "${diskPowerOnHours}" --post

		# Disk firmware
		diskFirmware=$(cat /root/smartctl-data | grep '^Firmware Version: ' | sed 's/Firmware Version: *//g')
		uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "disk_firmware" --value "${diskFirmware}" --post

		# Disk Power Cycles
		diskPowerCycles=$(cat /root/smartctl-data | grep -iP 'Power( |_)Cycle' | sed 's/[^0-9]//g')
		uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "disk_power_cycles" --value "${diskPowerCycles}" --post

		DISK="$i"
		if [[ $i =~ $NVME_REGEX ]]; then
			# Disk reads
			diskReads=$(echo "$(cat /root/smartctl-data | grep -i 'Data Units Read' | awk '{ print $4 }' | tr -d ',') * 512" | bc)
			# Disk writes
			diskWrites=$(echo "$(cat /root/smartctl-data | grep -i 'Data Units Written' | awk '{ print $4 }' | tr -d ',') * 512" | bc)
			diskType=nvme
			# Disk errors
			diskGenericErr=$(cat /root/smartctl-data | grep 'Error Information Log Entries:' | awk '{print $5}' | sed 's/,//g')
			diskDataErr=$(cat /root/smartctl-data | grep 'Media and Data Integrity Errors:' | awk '{print $6}' | sed 's/,//g')
			diskErrorCount=$(( diskGenericErr + diskDataErr ))
		elif [[ $i =~ $SSD_REGEX ]]; then
			diskReads=$(echo "$(cat /root/smartctl-data | grep '242 Total_LBAs_Read' | awk '{print $10}') * 512" | bc)
			diskWrites=$(echo "$(cat /root/smartctl-data | grep '242 Total_LBAs_Written' | awk '{print $10}') * 512" | bc)
			diskType=$(lsblk --nodeps --output NAME,ROTA | grep -i "${i}"  | awk '{ print $2 }' | tail -n 1)
				if [[ $diskType == "1" ]]; then
					diskType="hdd"
					else
					diskType="ssd"
				fi
			diskErrorCount=$(cat /root/smartctl-data | grep 'ATA Error Count:' | awk '{print $4}' | sed 's/,//g')
		else 
			diskType="unknown"
		fi

		# Disk reads
		uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "disk_reads_kb" --value "${diskReads}" --post

		# Disk writes
		uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "disk_writes_kb" --value "${diskWrites}" --post

		# Disk type
		uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "disk_type" --value "${diskType}" --post

		# Disk error count
		uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "disk_errors" --value "${diskErrorCount}" --post
	done
}

function collectSystemData {
# 53 cols in art
terminalCols=$(( $(tput cols) / 2 ))
# 5 rows in art, first number in tput cup
terminalRows=$(( $(tput lines) / 2 ))
if [[ $(tput cols) -gt 66 && $(tput lines) -gt 25 ]]; then
tput reset
printf '%s\n' "${BOLD}"
printf '%s\n' "${RED}"
tput cup 1 0
cat <<'EOF'
  _    _       _                    _ _             
 | |  | |     (_)                  (_) |            
 | |  | |_ __  ___   _____ _ __ ___ _| |_ _   _     
 | |  | | '_ \| \ \ / / _ \ '__/ __| | __| | | |    
 | |__| | | | | |\ V /  __/ |  \__ \ | |_| |_| |    
  \____/|_| |_|_| \_/ \___|_|  |___/_|\__|\__, |    
        / _| | |  | |               | |    __/ |    
   ___ | |_  | |__| | ___  _   _ ___| |_ _|___/ __  
  / _ \|  _| |  __  |/ _ \| | | / __| __/ _ \| '_ \ 
 | (_) | |   | |  | | (_) | |_| \__ \ || (_) | | | |
  \___/|_|   |_|  |_|\___/ \__,_|___/\__\___/|_| |_|                 
EOF

printf '%s\n' "${RESET}"
printf '%s\n' "${BOLD}"
tput cup 12 0
cat <<'EOF'
-----------------------------------------------------

  ___       __ _                         _         
 / __| ___ / _| |___ __ ____ _ _ _ ___  | |__ _  _ 
 \__ \/ _ \  _|  _\ V  V / _` | '_/ -_) | '_ \ || |
 |___/\___/_|  \__|\_/\_/\__,_|_| \___| |_.__/\_, |
                                              |__/ 
   ___                               ___             _    _       
  / __|__ _ _ __  ___ _ _ ___ _ _   | _ \__ _ ___ __| |_ | |_____ 
 | (__/ _` | '  \/ -_) '_/ _ \ ' \  |   / _` (_-</ _| ' \| / / -_)
  \___\__,_|_|_|_\___|_| \___/_||_| |_|_\__,_/__/\__|_||_|_\_\___|
EOF
printf '%s\n' "${RESET}"
printf '%s\n' "${BOLD}Inputting data into database...${RESET}"
fi

	printf "%s" "general|host_connected|1|${UUID}" | /opt/uit-toolbox/parse
	### DMI Data
	#t0 = BIOS
	#t1 = system
	#t2 = Base Board/Motherboard
	#t3 = Chassis
	#t4 = Processor
	#t22 = Battery
	#t32 = Boot Status

	# Ethernet MAC Address
	uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "ethernet_mac" --value "${etherAddr}" --post

	# WiFi MAC Address
	uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "wifi_mac" --value "${wifiMac}" --post

	# System Manufacturer
	systemManufacturer=$(dmidecode --string system-manufacturer)
	uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "system_manufacturer" --value "${systemManufacturer}" --post

	# System Model Name
	systemModel=$(dmidecode --string system-product-name)
	if [[ -z $systemModel ]]; then
		systemModel=$(cat /sys/class/dmi/id/product_name)
	fi
	uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "system_model" --value "${systemModel}" --post

	# System UUID
	systemUUID=$(dmidecode --string system-uuid)
	if [[ -z $systemUUID ]]; then
		systemUUID=$(cat /sys/class/dmi/id/product_uuid)
	fi
	uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "system_uuid" --value "${systemUUID}" --post

	# System SKU
	systemSKU=$(dmidecode --string system-sku-number)
	if [[ -z $systemSKU ]]; then
		systemSKU=$(cat /sys/class/dmi/id/product_sku)
	fi
	uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "system_sku" --value "${systemSKU}" --post

	# Chassis Type
	chassisType=$(dmidecode --string chassis-type | head -n1)
	uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "chassis_type" --value "${chassisType}" --post

	# CPU Manufacturer
	cpuManufacturer=$(dmidecode --string processor-manufacturer)
	uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "cpu_manufacturer" --value "${cpuManufacturer}" --post

	# CPU Model
	cpuModel=$(dmidecode --string processor-version)
	uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "cpu_model" --value "${cpuModel}" --post

	# CPU Max Speed
	cpuMaxSpeed=$(dmidecode -t4 | grep 'Max Speed' | sed 's/[^0-9]//g')
	uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "cpu_max_speed_mhz" --value "${cpuMaxSpeed}" --post

	# CPU Core Count
	cpuCoreCount=$(dmidecode -t4 | grep 'Core Count' | sed 's/Core Count: //g' | sed 's/^[[:space:]]*//g')
	uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "cpu_core_count" --value "${cpuCoreCount}" --post

	# CPU Thread Count
	cpuThreadCount=$(dmidecode -t4 | grep 'Thread Count' | sed 's/Thread Count: //g' | sed 's/^[[:space:]]*//g')
	uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "cpu_thread_count" --value "${cpuThreadCount}" --post

	# Motherboard Manufacturer
	motherboardManufacturer=$(dmidecode --string baseboard-manufacturer)
	uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "motherboard_manufacturer" --value "${motherboardManufacturer}" --post

	# Motherboard Serial
	motherboardSerial=$(dmidecode --string baseboard-serial-number)
	uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "motherboard_serial" --value "${motherboardSerial}" --post

	biosVersion=$(dmidecode --string bios-version 2>/dev/null)
	uit-cli --serial "${systemSerial}" --tag "${tagNum}"  --uuid "${UUID}" --key "bios_version" --value "${biosVersion}" --post
	biosDate=$(dmidecode --string bios-release-date 2>/dev/null)
	biosDateParsed=$(date --iso-8601=seconds --date "$biosDate" 2>/dev/null)
	if [[ -z $biosDateParsed ]]; then
		biosDateParsed=$biosDate # Make Go try to figure it out. Parsing in http.go
	fi
	uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "bios_release_date" --value "${biosDateParsed}" --post
	biosFirmwareRev=$(dmidecode --string firmware-revision 2>/dev/null)
	uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "bios_firmware" --value "${biosFirmwareRev}" --post
	systemSerial=$(dmidecode --string system-serial-number 2>/dev/null)

	###Disk Data
	collectDiskData

	###Memory Data
	memorySerial=$(dmidecode --type memory | grep -P '\tSerial Number' | awk '{ print $3 }' | tr '\n' ';' | sed 's/;$//g')
		uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "memory_serial" --value "${memorySerial}" --post
	memoryCapacity=$(grep '^MemTotal' /proc/meminfo | awk '{ print $2 }')
		uit-cli --tag "${tagNum}" --serial "${systemSerial}" --key "memory_capacity_kb" --value "${memoryCapacity}" --uuid "${UUID}" --post
	memSpeed=$(dmidecode --type 17 2>/dev/null | grep '^[[:space:]]*Speed\:' | head -n1 | sed 's/[^0-9]//g')
		uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "memory_speed_mhz" --value "${memSpeed}" --post

	###Boot Times
	# bootTime=$(systemd-analyze | grep -oP '[0-9]+[0-9.]*' | head -n 1)
	# 	uit-cli --serial "${systemSerial}" --key "boot_time" --value "${bootTime}" --uuid "${UUID}"

	tpmVersion=$(cat /sys/class/tpm/tpm0/tpm_version_major 2>/dev/null)
	uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "tpm_version" --value "${tpmVersion}" --post

	###Battery Data
		batteryDMIData=$(dmidecode -t22 2>/dev/null)
		if [[ $(cat /sys/class/power_supply/BAT0/present 2>/dev/null) == 1 || $(cat /sys/class/power_supply/BAT1/present 2>/dev/null) == 1 ]]; then
			batteryManufacturer=$(echo "$batteryDMIData" | grep -P '\tManufacturer' | head -n1 | sed 's/Manufacturer:[[:space:]]*//g')
			batteryManufactureDate=$(echo "$batteryDMIData" | grep -P '\t(SBDS )?Manufacture Date' | head -n1 | sed 's/[^0-9\/-]//g')
			if [[ $(cat /sys/class/power_supply/BAT0/present 2>/dev/null) == 1 ]]; then
				batteryMaxCurrentCapacity=$(cat /sys/class/power_supply/BAT0/charge_full 2>/dev/null)
				batteryFactoryCapacity=$(cat /sys/class/power_supply/BAT0/charge_full_design 2>/dev/null)
				batteryChargeCycles=$(cat /sys/class/power_supply/BAT0/cycle_count 2>/dev/null)
				batteryModel=$(echo "$batteryDMIData" | grep -P '\tName:' | head -n1 | sed 's/Name:[[:space:]]*//g')
					if [[ -z $batteryModel ]]; then
						batteryModel=$(cat /sys/class/power_supply/BAT0/model_name 2>/dev/null)
					fi 
				batterySerial=$(cat /sys/class/power_supply/BAT0/serial_number 2>/dev/null | awk '{ print $1 }')
			elif [[ $(cat /sys/class/power_supply/BAT1/present 2>/dev/null) == 1 ]]; then
				batteryMaxCurrentCapacity=$(cat /sys/class/power_supply/BAT1/energy_full 2>/dev/null)
				batteryFactoryCapacity=$(cat /sys/class/power_supply/BAT1/energy_full_design 2>/dev/null)
				batteryChargeCycles=$(cat /sys/class/power_supply/BAT1/cycle_count 2>/dev/null)
				batteryModel=$(echo "$batteryDMIData" | grep -P '\tName:' | head -n1 | sed 's/Name:[[:space:]]*//g')
					if [[ -z $batteryModel ]]; then
						batteryModel=$(cat /sys/class/power_supply/BAT1/model_name 2>/dev/null)
					fi
				batterySerial=$(cat /sys/class/power_supply/BAT1/serial_number 2>/dev/null | awk '{ print $1 }')
			fi
			uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "battery_current_max_capacity" --value "${batteryMaxCurrentCapacity}" --post
			uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "battery_design_capacity" --value "${batteryFactoryCapacity}" --post
			uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "battery_charge_cycles" --value "${batteryChargeCycles}" --post
			uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "battery_model" --value "${batteryModel}" --post
			uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "battery_serial" --value "${batterySerial}" --post
			uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "battery_manufacturer" --value "${batteryManufacturer}" --post
			uit-cli --serial "${systemSerial}" --tag "${tagNum}" --uuid "${UUID}" --key "battery_manufacture_date" --value "${batteryManufactureDate}" --post
		fi

	printf "%s" "system-stats|cpu|${UUID}" | /opt/uit-toolbox/parse
	printf "%s" "system-stats|network|${UUID}" | /opt/uit-toolbox/parse
}

function checkNetwork {
	local i=0
	while [ $i -lt 10 ]; do
		ping -c 1 UIT_CLIENT_PING_HOST &>/dev/null
		if [[ $? == 0 ]]; then
			return
		else
			if [[ -n $netInterfaceName ]]; then
				driverName=$(basename $(readlink -f /sys/class/net/${netInterfaceName}/device/driver) 2>/dev/null)
				if [[ -n $driverName ]]; then
					pciBusAddr=$(basename $(find /sys/bus/pci/drivers/${driverName} -name "0000*"))
					if [[ -n $pciBusAddr ]]; then
						ethtool -K ${netInterfaceName} tso off gso off gro off wol off
						echo "on" | sudo tee /sys/bus/pci/devices/${pciBusAddr}/power/control
					fi
				fi
			fi
			((i++))
			dhclient -r
			dhclient -4
			sleep 1
			ping -c 1 UIT_CLIENT_PING_HOST &>/dev/null
			if [[ $? == 0 ]]; then
				return
			else
				checkNetwork
			fi
		fi
	done
}

function findIdentityInDB {
	tput reset
	printf '\n'

	UUID=""
	UUID=$(uit-cli --key "new_transaction_uuid" --get | jq -r '.transaction_uuid' 2>/dev/null)
	if [[ -z $UUID ]]; then
		UUID=$(cat /proc/sys/kernel/random/uuid)
	fi

	systemSerial=$(dmidecode --string system-serial-number 2>/dev/null)
	tagNum=$(uit-cli --serial "${systemSerial}" --key "client_lookup_by_serial" --value "${systemSerial}" --get | jq -r '.tagnumber' 2>/dev/null)

	if [[ -n $tagNum && $tagNum != "null" ]]; then
		uit-cli --serial "${systemSerial}" --tag "${tagNum}" --key "init" --value "${systemSerial}" --uuid "${UUID}" --post
		coproc uit_cpu { uit-cpu 2>/dev/null; }
		coproc uit_network { uit-network 2>/dev/null; }
		coproc uit_sql { uit-sql 2>/dev/null; }
		coproc uit_screenshot { uit-screenshot 2>/dev/null; }
		return
	else
		read -p "${BOLD}Please enter the ${GREEN}6-digit tag number${RESET} ${BOLD}followed by ${GREEN}Enter${RESET}${BOLD}:${RESET} " tagNum
		printf '\n'

		tagNum=$(echo "${tagNum}" | sed 's/[^0-9]//g' | head -c 6)
		if [[ -z $tagNum ]]; then
			printf '%s\n' "${RED}Error: Tag number cannot be empty. Please try again.${RESET}"
			findIdentityInDB
		fi
		uit-cli --serial "${systemSerial}" --tag "${tagNum}" --key "init" --value "${systemSerial}" --uuid "${UUID}" --post
		# printf "%s" "location|custom|${tagNum}|${systemSerial}|new entry|0|" | /opt/uit-toolbox/parse
		findIdentityInDB
	fi
}

function jobInfo {
	if [[ $ACTION != "" ]]; then
		printf '%s\n' "The selected mode is ${BOLD}${ACTION}${RESET}"
	fi

	if [[ $CLIENTDISK != "" ]]; then
		printf '%s\n' "The selected disk is ${BOLD}${CLIENTDISK}${RESET}"
	fi

	if [[ $cloneMode != "" ]]; then
		printf '%s\n' "The selected clone mode is ${BOLD}${cloneMode}${RESET}"
	fi
	if [[ $cloneImgName != "" ]]; then
		printf '%s\n' "The selected image is ${BOLD}${cloneImgName}${RESET}"
	fi

	printf '\n'
}

function footer {
	biosUpdatedSQL=$(printf "%s" "SELECT bios_version AS result FROM static_bios_stats WHERE system_model = '${systemModel}'" | /opt/uit-toolbox/select 2>/dev/null)
	if [[ $biosUpdatedSQL == "NULL" ]]; then
		biosUpdated="$(dmidecode --string bios-version)"
	elif [[ $biosUpdatedSQL == $(dmidecode --string bios-version) ]]; then
		biosUpdated="${GREEN}Updated${RESET}"
	elif [[ $biosUpdatedSQL != $(dmidecode --string bios-version) ]]; then
		biosUpdated="${RED}Needs Update${RESET}"
	fi
	sqlLocation=$(printf "%s" "SELECT location AS result FROM locations WHERE tagnumber = '${tagNum}' ORDER BY time DESC LIMIT 1" | /opt/uit-toolbox/select 2>/dev/null)

	batCharge=""
	batStatus=""
	if [[ -d /sys/class/power_supply/BAT0 ]]; then
    batCharge=$(cat /sys/class/power_supply/BAT0/capacity)
    batStatus=$(cat /sys/class/power_supply/BAT0/status)
	elif [[ -d /sys/class/power_supply/BAT1 ]]; then
		batCharge=$(cat /sys/class/power_supply/BAT1/capacity)
		batStatus=$(cat /sys/class/power_supply/BAT1/status)
	fi

	sqlOS=$(printf "%s" "SELECT os_name AS result FROM client_health WHERE tagnumber = '${tagNum}'" | /opt/uit-toolbox/select 2>/dev/null)
	batCharge=${GREEN}${batCharge}${RESET}
	tput reset
	lines=$(tput lines)
	tput cup $(( lines - 4 )) 0
	tput el
	printf '%s%s %s%s\n' "Tag: ${tagNum}, Serial: ${systemSerial}, Location: \"${sqlLocation}\", Time:" $(date "+%m/%d/%y") $(date "+%r") "${RESET}"
	tput cup $(( lines - 3 )) 0
	tput el 
	printf '%s\n' "Battery: ${GREEN}${batCharge}%${RESET}, BIOS: ${biosUpdated}${RESET}, OS: ${BLUE}${sqlOS}${RESET}"
	tput cup $(( lines - 2 )) 0
	tput el
	printf '%s\n' "${DIM}UIT-Toolbox Client by ${RESET}Cameron Raschke${DIM} (caraschke@uh.edu). ${RESET}${RED}Go coogs!!${RESET}"
	tput cup 1 0
}

